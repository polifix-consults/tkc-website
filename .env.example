# Supabase Configuration
# Get these values from Supabase Dashboard > Settings > API

# Your Supabase project URL (Public - visible in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon public API key (Public - visible in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (PRIVATE - server-side only)
# ⚠️ DO NOT expose this to the browser or commit to version control
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
